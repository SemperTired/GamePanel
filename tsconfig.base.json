{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@aetherpanel/shared": ["packages/shared/src/index.ts"],
      "@aetherpanel/templates": ["packages/templates/src/index.ts"],
      "@aetherpanel/runtime-docker": ["packages/runtime-docker/src/index.ts"]
    }
  }
}
