NODE_ENV=development
PUBLIC_APP_URL=http://127.0.0.1:4000
API_PORT=4100
WEB_PORT=4000
DATABASE_REQUIRED=false
REDIS_REQUIRED=false
PROVISIONING_QUEUE=redis
AETHERPANEL_DATA_ROOT=./var/services
AETHERPANEL_CACHE_ROOT=./var/services/_cache
AETHERPANEL_RUN_INSTALLERS=false
AETHERPANEL_INSTALL_TIMEOUT_MS=1800000
AETHERNODE_WAN_IP=
NODE_BIND_IP=0.0.0.0
NODE_LAN_IP=127.0.0.1
PORT_POOL_START=30000
PORT_POOL_END=60000
NETWORK_APPLY_MODE=dry_run
FILE_MANAGER_MAX_READ_BYTES=1048576

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=aetherpanel
POSTGRES_USER=aetherpanel
POSTGRES_PASSWORD=change-me
POSTGRES_CONNECT_TIMEOUT_MS=1500

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
PROVISIONING_JOB_ATTEMPTS=3
PROVISIONING_CONCURRENCY=2
PROVISIONING_QUEUE_TIMEOUT_MS=3000

JWT_SECRET=replace-with-openssl-rand-hex-48
ENCRYPTION_KEY=replace-with-32-byte-base64-key
SUPERADMIN_EMAIL=admin@aetherpanel.local
SUPERADMIN_PASSWORD=change-me-now

PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_RETURN_URL=https://aethernode.org/checkout/paypal/return
PAYPAL_CANCEL_URL=https://aethernode.org/checkout/paypal/cancel
PAYPAL_WEBHOOK_URL=https://aethernode.org/api/v1/billing/paypal/webhook
PAYPAL_CURRENCY=USD
AETHERPANEL_FULFILLMENT_SECRET=replace-with-shared-secret-between-aethernode-and-aetherpanel

STEAM_WEB_API_KEY=
STEAMCMD_USERNAME=
STEAMCMD_PASSWORD=
ALDERON_INSTALLER_PATH=
ALDERON_EMAIL=
ALDERON_PASSWORD=
FIVEM_LICENSE_KEY=
FIVEM_ARTIFACT_CHANNEL=recommended
NEXUSMODS_API_KEY=
MODIO_API_KEY=
CURSEFORGE_API_KEY=

UNIFI_OS_BASE_URL=
UNIFI_OS_SITE_ID=default
UNIFI_OS_USERNAME=
UNIFI_OS_PASSWORD=
UNIFI_OS_DRY_RUN=true
